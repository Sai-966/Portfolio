<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Sai Abhinay — DevOps / Platform Engineer</title>
<meta name="description" content="Thudigeni Sai Abhinay — DevOps / DevSecOps & Platform Engineer. GitOps delivery platforms on AWS EKS, ArgoCD, Kubernetes, and zero-downtime releases." />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600;700;800;900&family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
<style>
  :root{
    --ink:#05080F; --ink2:#080D18; --panel:#0D1322; --panel-2:#111A2D;
    --line:rgba(150,167,196,.12); --line-2:rgba(150,167,196,.22);
    --amber:#FFB02E; --amber-2:#FFC868; --amber-glow:rgba(255,176,46,.30);
    --mint:#3BE3A6; --mint-2:#86F0CC; --mint-glow:rgba(59,227,166,.26);
    --red:#FF5A6E;
    --text:#EAF0FA; --muted:#94A2BC; --dim:#5B6783;
    --display:'Archivo',sans-serif; --body:'IBM Plex Sans',sans-serif; --mono:'IBM Plex Mono',monospace;
    --maxw:1180px;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{
    font-family:var(--body); background:var(--ink); color:var(--text);
    line-height:1.6; -webkit-font-smoothing:antialiased; overflow-x:hidden;
    background-image:
      radial-gradient(900px 600px at 78% -8%, rgba(255,176,46,.10), transparent 60%),
      radial-gradient(820px 560px at 6% 8%, rgba(59,227,166,.07), transparent 60%);
    background-attachment:fixed;
  }
  a{color:inherit;text-decoration:none}
  ::selection{background:var(--amber);color:#1a1205}
  :focus-visible{outline:2px solid var(--amber);outline-offset:3px;border-radius:3px}

  .wrap{max-width:var(--maxw);margin:0 auto;padding:0 28px;width:100%}

  /* ---------- top bar ---------- */
  .bar{position:sticky;top:0;z-index:60;transition:background .3s ease,border-color .3s ease,backdrop-filter .3s}
  .bar.scrolled{background:rgba(5,8,15,.72);backdrop-filter:blur(12px);border-bottom:1px solid var(--line)}
  .bar-in{display:flex;align-items:center;justify-content:space-between;height:68px}
  .brand{display:flex;align-items:center;gap:11px;font-family:var(--mono);font-size:.86rem;color:var(--muted);letter-spacing:.02em}
  .logo{width:30px;height:30px;display:grid;place-items:center;font-family:var(--display);font-weight:900;font-size:.92rem;
    color:#160f02;background:linear-gradient(135deg,var(--amber),var(--amber-2));border-radius:7px;box-shadow:0 0 18px var(--amber-glow)}
  .brand b{color:var(--text);font-weight:600}
  nav.links{display:flex;align-items:center;gap:30px}
  nav.links a{font-family:var(--mono);font-size:.8rem;letter-spacing:.04em;color:var(--muted);transition:color .2s;position:relative;padding:4px 0}
  nav.links a:hover{color:var(--text)}
  nav.links a.active{color:var(--amber)}
  nav.links a.active::after{content:"";position:absolute;left:0;right:0;bottom:-2px;height:2px;background:var(--amber);box-shadow:0 0 10px var(--amber-glow)}
  .bar-cta{font-family:var(--mono);font-size:.78rem;letter-spacing:.04em;color:var(--ink);background:var(--amber);
    padding:9px 15px;border-radius:8px;font-weight:600;transition:transform .15s,box-shadow .2s;display:none}
  .bar-cta:hover{transform:translateY(-1px);box-shadow:0 6px 22px var(--amber-glow)}

  /* ---------- promotion rail ---------- */
  .rail{position:fixed;left:max(14px,calc((100vw - var(--maxw))/2 - 30px));top:50%;transform:translateY(-50%);z-index:40;display:flex;flex-direction:column;gap:0}
  .rail::before{content:"";position:absolute;left:6px;top:10px;bottom:10px;width:2px;background:var(--line-2);border-radius:2px}
  .rstep{display:flex;align-items:center;padding:11px 0;position:relative;cursor:pointer}
  .rdot{width:14px;height:14px;border-radius:50%;border:2px solid var(--dim);background:var(--ink);transition:all .3s;flex:0 0 auto;z-index:1}
  .rlabel{position:absolute;left:26px;top:50%;transform:translateY(-50%) translateX(-6px);opacity:0;pointer-events:none;white-space:nowrap;
    font-family:var(--mono);font-size:.62rem;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);
    background:var(--panel-2);border:1px solid var(--line-2);padding:5px 10px;border-radius:7px;box-shadow:0 8px 22px rgba(0,0,0,.45);transition:opacity .2s,transform .2s,color .2s,border-color .2s}
  .rstep:hover .rlabel{opacity:1;transform:translateY(-50%) translateX(0)}
  .rstep.passed .rdot{border-color:var(--mint);background:var(--mint);box-shadow:0 0 10px var(--mint-glow)}
  .rstep.active .rdot{border-color:var(--amber);background:var(--amber);box-shadow:0 0 14px var(--amber-glow);transform:scale(1.18)}
  .rstep.active .rlabel{color:var(--amber);border-color:rgba(255,176,46,.4)}

  /* ---------- hero ---------- */
  .hero{position:relative;padding:84px 0 70px;overflow:hidden}
  .hero::before{content:"";position:absolute;inset:0;z-index:-1;
    background-image:linear-gradient(var(--line) 1px,transparent 1px),linear-gradient(90deg,var(--line) 1px,transparent 1px);
    background-size:46px 46px;
    mask-image:radial-gradient(120% 90% at 60% 30%, #000 35%, transparent 78%);
    -webkit-mask-image:radial-gradient(120% 90% at 60% 30%, #000 35%, transparent 78%);opacity:.7}
  .status{display:inline-flex;align-items:center;gap:9px;font-family:var(--mono);font-size:.76rem;letter-spacing:.04em;
    color:var(--mint-2);border:1px solid rgba(59,227,166,.32);background:rgba(59,227,166,.06);padding:7px 14px;border-radius:100px}
  .status .blip{width:8px;height:8px;border-radius:50%;background:var(--mint);box-shadow:0 0 0 0 var(--mint-glow);animation:blip 2.4s infinite}
  @keyframes blip{0%{box-shadow:0 0 0 0 var(--mint-glow)}70%{box-shadow:0 0 0 8px transparent}100%{box-shadow:0 0 0 0 transparent}}
  .eyebrow{font-family:var(--mono);font-size:.82rem;letter-spacing:.16em;text-transform:uppercase;color:var(--amber)}
  .eyebrow .s{color:var(--dim)}
  h1.name{font-family:var(--display);font-weight:900;line-height:.9;letter-spacing:-.025em;font-size:clamp(2.9rem,9.4vw,6.6rem);
    margin:18px 0 0;color:#fff}
  h1.name .l2{color:transparent;-webkit-text-stroke:1.6px var(--amber-2);background:linear-gradient(180deg,#fff,#cfd8ea);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
  .role{font-family:var(--mono);font-size:clamp(.95rem,2.4vw,1.18rem);letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-top:18px}
  .role b{color:var(--amber);font-weight:500}
  .tagline{max-width:660px;margin-top:22px;font-size:clamp(1.05rem,2.3vw,1.32rem);color:#cdd7e8;line-height:1.5}
  .tagline em{font-style:normal;color:var(--mint-2)}

  /* ---------- pipeline (signature) ---------- */
  .pipe-card{margin-top:42px;border:1px solid var(--line-2);background:linear-gradient(180deg,rgba(17,26,45,.72),rgba(10,15,28,.72));
    border-radius:16px;padding:22px 24px 24px;backdrop-filter:blur(6px);box-shadow:0 24px 70px rgba(0,0,0,.45)}
  .pipe-top{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:22px}
  .pipe-tag{font-family:var(--mono);font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);display:flex;align-items:center;gap:9px}
  .pipe-tag .dot{width:7px;height:7px;border-radius:50%;background:var(--amber);box-shadow:0 0 10px var(--amber-glow);animation:blip 2s infinite}
  .pipe-state{font-family:var(--mono);font-size:.72rem;letter-spacing:.06em;color:var(--mint-2)}

  .pipe{position:relative;display:flex;align-items:flex-start;padding:6px 0 4px}
  .pipe-line{position:absolute;left:8.333%;width:83.333%;top:34px;height:3px;border-radius:3px;overflow:hidden;
    background:rgba(150,167,196,.16)}
  .pipe-line::after{content:"";position:absolute;inset:0;
    background:repeating-linear-gradient(90deg,transparent 0 9px,var(--amber) 9px 17px);opacity:.55;
    background-size:200% 100%;animation:flow 1.1s linear infinite}
  @keyframes flow{to{background-position:-34px 0}}
  .packet{position:absolute;top:34px;width:16px;height:16px;border-radius:50%;margin-top:-6.5px;left:8.333%;
    background:var(--amber);box-shadow:0 0 0 4px rgba(255,176,46,.18),0 0 20px var(--amber);transform:translateX(-50%);z-index:3}
  .stage{flex:1 1 0;display:flex;flex-direction:column;align-items:center;gap:11px;position:relative;z-index:2;min-width:0}
  .node{width:60px;height:60px;border-radius:14px;display:grid;place-items:center;background:var(--ink2);border:1.5px solid var(--line-2);
    color:var(--dim);transition:all .35s ease;position:relative}
  .node svg{width:24px;height:24px;stroke:currentColor;fill:none;stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round}
  .slabel{font-family:var(--mono);font-size:.7rem;letter-spacing:.04em;color:var(--dim);transition:color .35s;text-align:center;white-space:nowrap}
  .stage.passed .node{color:var(--mint);border-color:rgba(59,227,166,.5);background:rgba(59,227,166,.06)}
  .stage.passed .slabel{color:var(--muted)}
  .stage.active .node{color:#1a1205;border-color:var(--amber);background:linear-gradient(135deg,var(--amber),var(--amber-2));
    box-shadow:0 0 26px var(--amber-glow);transform:translateY(-3px) scale(1.05)}
  .stage.active .slabel{color:var(--amber)}

  .stats{display:flex;flex-wrap:wrap;gap:26px 38px;margin-top:36px;border-top:1px solid var(--line);padding-top:26px}
  .stat .n{font-family:var(--display);font-weight:800;font-size:clamp(1.7rem,4vw,2.5rem);line-height:1;color:#fff}
  .stat .n .u{color:var(--amber);font-size:.62em}
  .stat .k{font-family:var(--mono);font-size:.7rem;letter-spacing:.13em;text-transform:uppercase;color:var(--muted);margin-top:9px}

  .cta-row{display:flex;flex-wrap:wrap;gap:14px;margin-top:34px}
  .btn{font-family:var(--mono);font-size:.82rem;letter-spacing:.04em;padding:13px 22px;border-radius:10px;font-weight:500;
    display:inline-flex;align-items:center;gap:10px;transition:transform .15s,box-shadow .2s,border-color .2s,background .2s;cursor:pointer}
  .btn.primary{background:var(--amber);color:#160f02;font-weight:600}
  .btn.primary:hover{transform:translateY(-2px);box-shadow:0 10px 30px var(--amber-glow)}
  .btn.ghost{border:1px solid var(--line-2);color:var(--text);background:transparent}
  .btn.ghost:hover{border-color:var(--amber);color:var(--amber);transform:translateY(-2px)}
  .btn svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}

  /* ---------- sections ---------- */
  .sec{padding:96px 0;position:relative;scroll-margin-top:84px}
  .sec-head{margin-bottom:48px;max-width:760px}
  .sec-head h2{font-family:var(--display);font-weight:800;letter-spacing:-.015em;line-height:1.02;
    font-size:clamp(2rem,5.2vw,3.5rem);color:#fff;margin-top:16px}
  .sec-head .lead{color:var(--muted);font-size:1.05rem;margin-top:14px;max-width:620px}

  /* about */
  .about-grid{display:grid;grid-template-columns:1.25fr .95fr;gap:46px;align-items:start}
  .about-copy p{color:#c7d2e6;font-size:1.08rem;line-height:1.72}
  .about-copy p + p{margin-top:18px}
  .about-copy strong{color:var(--text);font-weight:600}
  .manifest{font-family:var(--mono);font-size:.86rem;background:var(--panel);border:1px solid var(--line-2);border-radius:14px;
    overflow:hidden;box-shadow:0 18px 50px rgba(0,0,0,.4)}
  .manifest-bar{display:flex;align-items:center;gap:7px;padding:13px 16px;border-bottom:1px solid var(--line);background:rgba(255,255,255,.02)}
  .manifest-bar i{width:11px;height:11px;border-radius:50%;display:inline-block}
  .mdot1{background:var(--red)} .mdot2{background:var(--amber)} .mdot3{background:var(--mint)}
  .manifest-bar span{margin-left:8px;color:var(--dim);font-size:.74rem;letter-spacing:.06em}
  .manifest-body{padding:18px 18px 20px;line-height:1.95}
  .manifest .k{color:var(--muted)} .manifest .s{color:var(--mint-2)} .manifest .a{color:var(--amber-2)} .manifest .p{color:var(--dim)}
  .manifest .ok{color:var(--mint)}

  /* stack */
  .stack-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(252px,1fr));gap:16px}
  .cat{border:1px solid var(--line-2);background:var(--panel);border-radius:13px;padding:20px;transition:border-color .25s,transform .25s,background .25s}
  .cat:hover{border-color:rgba(255,176,46,.4);transform:translateY(-3px);background:var(--panel-2)}
  .cat h3{font-family:var(--mono);font-size:.74rem;letter-spacing:.13em;text-transform:uppercase;color:var(--amber);margin-bottom:15px;display:flex;align-items:center;gap:8px}
  .cat h3::before{content:"";width:6px;height:6px;background:var(--amber);border-radius:1px;box-shadow:0 0 8px var(--amber-glow)}
  .chips{display:flex;flex-wrap:wrap;gap:8px}
  .chip{font-family:var(--mono);font-size:.78rem;color:#cbd5e8;border:1px solid var(--line);background:rgba(255,255,255,.02);
    padding:6px 11px;border-radius:7px;transition:all .2s}
  .chip:hover{border-color:var(--mint);color:var(--mint-2);background:rgba(59,227,166,.06)}

  /* experience timeline */
  .tl{position:relative;padding-left:30px}
  .tl::before{content:"";position:absolute;left:5px;top:8px;bottom:8px;width:2px;background:linear-gradient(180deg,var(--amber),var(--line-2) 40%,var(--line-2))}
  .job{position:relative;margin-bottom:34px}
  .job::before{content:"";position:absolute;left:-30px;top:7px;width:12px;height:12px;border-radius:50%;background:var(--ink);border:2px solid var(--dim);transform:translateX(0)}
  .job.feat::before{border-color:var(--amber);background:var(--amber);box-shadow:0 0 14px var(--amber-glow)}
  .card{border:1px solid var(--line-2);background:var(--panel);border-radius:14px;padding:24px;transition:border-color .25s}
  .job.feat .card{border-color:rgba(255,176,46,.4);background:linear-gradient(180deg,rgba(255,176,46,.05),var(--panel))}
  .card:hover{border-color:var(--line-2)}
  .job.feat .card:hover{border-color:rgba(255,176,46,.6)}
  .jdate{font-family:var(--mono);font-size:.74rem;letter-spacing:.08em;color:var(--mint-2);text-transform:uppercase}
  .jrole{font-family:var(--display);font-weight:800;font-size:1.4rem;color:#fff;margin-top:8px;letter-spacing:-.01em}
  .jrole span{color:var(--amber)}
  .feat-tag{display:inline-block;font-family:var(--mono);font-size:.64rem;letter-spacing:.14em;text-transform:uppercase;color:#160f02;
    background:var(--amber);padding:3px 9px;border-radius:5px;font-weight:600;margin-bottom:14px}
  .proj{font-family:var(--mono);font-size:.82rem;color:var(--muted);margin-top:6px;padding-bottom:14px;border-bottom:1px dashed var(--line);margin-bottom:16px}
  .proj b{color:var(--text);font-weight:500}
  ul.pts{list-style:none;display:flex;flex-direction:column;gap:11px}
  ul.pts li{position:relative;padding-left:22px;color:#c2cde2;font-size:.97rem;line-height:1.6}
  ul.pts li::before{content:"";position:absolute;left:0;top:9px;width:9px;height:2px;background:var(--amber);border-radius:2px}
  ul.pts li b{color:var(--text);font-weight:600}
  .subproj{margin-top:20px;padding-top:18px;border-top:1px solid var(--line)}

  .edu{display:flex;align-items:center;gap:16px;flex-wrap:wrap;margin-top:30px;border:1px solid var(--line);border-radius:12px;padding:18px 22px;background:var(--panel)}
  .edu .ic{width:38px;height:38px;border-radius:9px;display:grid;place-items:center;color:var(--mint);border:1px solid rgba(59,227,166,.4);background:rgba(59,227,166,.06)}
  .edu .ic svg{width:19px;height:19px;stroke:currentColor;fill:none;stroke-width:1.7}
  .edu b{color:#fff;font-weight:600}
  .edu .meta{font-family:var(--mono);font-size:.78rem;color:var(--muted)}

  /* contact */
  .contact{text-align:center;padding:110px 0 96px}
  .contact h2{font-family:var(--display);font-weight:900;letter-spacing:-.02em;font-size:clamp(2.2rem,6.4vw,4.4rem);line-height:1;color:#fff;margin-top:18px}
  .contact h2 em{font-style:normal;color:transparent;-webkit-text-stroke:1.4px var(--amber);background-clip:text;-webkit-background-clip:text}
  .contact p{color:var(--muted);max-width:520px;margin:20px auto 0;font-size:1.06rem}
  .contact-row{display:flex;flex-wrap:wrap;gap:13px;justify-content:center;margin-top:36px}
  .cloc{font-family:var(--mono);font-size:.8rem;color:var(--dim);letter-spacing:.06em;margin-top:30px}

  footer{border-top:1px solid var(--line);padding:28px 0}
  .foot-in{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;
    font-family:var(--mono);font-size:.76rem;color:var(--dim);letter-spacing:.04em}
  .foot-in .ops{color:var(--mint-2);display:inline-flex;align-items:center;gap:8px}
  .foot-in .ops i{width:7px;height:7px;border-radius:50%;background:var(--mint);box-shadow:0 0 8px var(--mint-glow)}

  /* reveal */
  .reveal{opacity:0;transform:translateY(20px);transition:opacity .7s cubic-bezier(.2,.7,.2,1),transform .7s cubic-bezier(.2,.7,.2,1)}
  .reveal.in{opacity:1;transform:none}

  /* responsive */
  @media(max-width:1199px){ .rail{display:none} }
  @media(max-width:860px){
    .about-grid{grid-template-columns:1fr;gap:30px}
    .sec{padding:74px 0}
  }
  @media(max-width:680px){
    nav.links{display:none}
    .bar-cta{display:inline-flex}
    .wrap{padding:0 20px}
    .node{width:50px;height:50px;border-radius:11px}
    .node svg{width:21px;height:21px}
    .pipe-line,.packet{top:30px}
    .stats{gap:20px 28px}
  }
  @media(max-width:520px){
    .slabel{display:none}
    .pipe-card{padding:18px 16px 20px}
    .node{width:44px;height:44px}
    .node svg{width:19px;height:19px}
    .pipe-line,.packet{top:27px}
  }
  @media(prefers-reduced-motion:reduce){
    html{scroll-behavior:auto}
    .reveal{opacity:1;transform:none;transition:none}
    .pipe-line::after,.packet,.blip{animation:none!important}
    .status .blip,.pipe-tag .dot{animation:none}
  }
</style>
</head>
<body>

<!-- promotion rail -->
<aside class="rail" aria-hidden="true">
  <div class="rstep" data-env="about"><span class="rdot"></span><span class="rlabel">dev</span></div>
  <div class="rstep" data-env="stack"><span class="rdot"></span><span class="rlabel">qa</span></div>
  <div class="rstep" data-env="experience"><span class="rdot"></span><span class="rlabel">pre-prod</span></div>
  <div class="rstep" data-env="contact"><span class="rdot"></span><span class="rlabel">prod</span></div>
</aside>

<!-- top bar -->
<header class="bar" id="bar">
  <div class="wrap bar-in">
    <a class="brand" href="#top"><span class="logo">SA</span><span>// <b>sai_abhinay</b></span></a>
    <nav class="links">
      <a href="#about">About</a>
      <a href="#stack">Stack</a>
      <a href="#experience">Experience</a>
      <a href="#contact">Contact</a>
    </nav>
    <a class="bar-cta" href="mailto:saiabhinay67@gmail.com">Email</a>
  </div>
</header>

<main id="top">

  <!-- HERO -->
  <section class="hero">
    <div class="wrap">
      <span class="status reveal"><span class="blip"></span>Open to senior DevOps &amp; Platform Engineering roles</span>
      <p class="eyebrow reveal" style="margin-top:24px"><span class="s">//</span> release: portfolio.v4 &middot; ready to ship</p>
      <h1 class="name reveal">THUDIGENI<br><span class="l2">SAI ABHINAY</span></h1>
      <p class="role reveal">DevOps <b>/</b> DevSecOps <b>/</b> Platform Engineer</p>
      <p class="tagline reveal">I build GitOps delivery platforms that promote code from commit to production — <em>automated, secured, and zero-downtime.</em></p>

      <!-- signature: live pipeline -->
      <div class="pipe-card reveal">
        <div class="pipe-top">
          <span class="pipe-tag"><span class="dot"></span>continuous delivery &middot; live</span>
          <span class="pipe-state" id="pipeState">syncing&hellip;</span>
        </div>
        <div class="pipe" id="pipe">
          <div class="pipe-line"></div>
          <div class="packet" id="packet"></div>
          <div class="stage" data-i="0"><span class="node"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="4"/><line x1="1.5" y1="12" x2="8" y2="12"/><line x1="16" y1="12" x2="22.5" y2="12"/></svg></span><span class="slabel">Commit</span></div>
