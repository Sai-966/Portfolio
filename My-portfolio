<script>
(function(){
  var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // sticky bar
  var bar = document.getElementById('bar');
  function onScroll(){ if(window.scrollY > 24) bar.classList.add('scrolled'); else bar.classList.remove('scrolled'); }
  window.addEventListener('scroll', onScroll, {passive:true}); onScroll();

  // reveal on scroll
  var revs = document.querySelectorAll('.reveal');
  if('IntersectionObserver' in window && !reduce){
    var io = new IntersectionObserver(function(es){
      es.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); } });
    },{threshold:.12, rootMargin:'0px 0px -8% 0px'});
    revs.forEach(function(el){ io.observe(el); });
  } else { revs.forEach(function(el){ el.classList.add('in'); }); }

  // nav + rail active state
  var sections = ['about','stack','experience','contact'];
  var navLinks = {}, railSteps = {};
  document.querySelectorAll('nav.links a').forEach(function(a){ navLinks[a.getAttribute('href').slice(1)] = a; });
  document.querySelectorAll('.rstep').forEach(function(s){ railSteps[s.getAttribute('data-env')] = s; });
  document.querySelectorAll('.rstep').forEach(function(s){
    s.addEventListener('click', function(){ var t=document.getElementById(s.getAttribute('data-env')); if(t) t.scrollIntoView(); });
  });
  function setActive(id){
    sections.forEach(function(sec,i){
      var on = sec===id, idx = sections.indexOf(id);
      if(navLinks[sec]) navLinks[sec].classList.toggle('active', on);
      if(railSteps[sec]){
        railSteps[sec].classList.toggle('active', on);
        railSteps[sec].classList.toggle('passed', idx>-1 && i<idx);
      }
    });
  }
  if('IntersectionObserver' in window){
    var so = new IntersectionObserver(function(es){
      es.forEach(function(e){ if(e.isIntersecting) setActive(e.target.id); });
    },{rootMargin:'-45% 0px -45% 0px'});
    sections.forEach(function(id){ var el=document.getElementById(id); if(el) so.observe(el); });
  }

  // ---- live pipeline ----
  var stages = Array.prototype.slice.call(document.querySelectorAll('#pipe .stage'));
  var packet = document.getElementById('packet');
  var stateEl = document.getElementById('pipeState');
  var n = stages.length;
  var labels = ['committing','building','scanning','packaging','promoting','deploying'];

  function render(activeIdx){
    stages.forEach(function(st,i){
      st.classList.toggle('active', i===activeIdx);
      st.classList.toggle('passed', i<activeIdx);
    });
  }

  if(reduce || n===0){
    // static synced state
    stages.forEach(function(st){ st.classList.add('passed'); });
    if(packet) packet.style.display='none';
    if(stateEl) stateEl.textContent = '● synced';
  } else {
    var DUR = 5600, start = null;
    function frame(ts){
      if(start===null) start = ts;
      var pos = ((ts - start) % DUR) / DUR;             // 0..1
      var leftFrac = (0.5 + pos*(n-1)) / n;             // along node centers
      packet.style.left = (leftFrac*100) + '%';
      var ai = Math.min(n-1, Math.round(pos*(n-1)));
      render(ai);
      if(stateEl) stateEl.textContent = (ai===n-1 && pos>0.92) ? '✓ deployed → prod' : labels[ai] + '…';
      requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);
  }
})();
</script>
